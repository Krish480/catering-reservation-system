<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Order Success</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 font-sans text-center py-20">
  <h1 class="text-3xl font-bold text-green-600">✅ Order Placed Successfully!</h1>
  <p class="mt-4 text-gray-700">Your order ID: <span class="font-mono"><%= order.id %></span></p>
  <p class="mt-2 text-gray-500">Total Amount: ₹<%= order.total %></p>
  <a href="/menu" class="mt-6 inline-block bg-orange-600 text-white px-6 py-3 rounded-lg hover:bg-orange-700">Back to Menu</a>
</body>
</html>
