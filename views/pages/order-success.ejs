<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Order Success - MealMatrix</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    /* simple fade + scale animation */
    @keyframes fadeScale {
      0% { opacity: 0; transform: scale(0.9); }
      100% { opacity: 1; transform: scale(1); }
    }
    .animate-fadeScale {
      animation: fadeScale 0.6s ease-out forwards;
    }
  </style>
</head>
<body class="bg-gradient-to-br from-orange-50 to-orange-100 font-sans flex items-center justify-center min-h-screen px-4">

  <div class="bg-white shadow-xl rounded-2xl p-8 max-w-md w-full animate-fadeScale">
    <div class="flex justify-center mb-6">
      <div class="w-20 h-20 rounded-full bg-green-100 flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-green-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>
    </div>
    
    <h1 class="text-2xl sm:text-3xl font-bold text-green-600 text-center">Order Placed Successfully!</h1>
    <p class="mt-4 text-gray-700 text-center">Thank you for your order 🎉</p>

    <div class="mt-6 bg-gray-50 rounded-lg p-4 text-center">
      <p class="text-gray-600">Order ID:</p>
      <p class="font-mono font-semibold text-lg text-gray-800"><%= order.id %></p>
      <p class="mt-3 text-gray-600">Total Amount:</p>
      <p class="text-2xl font-bold text-orange-600">₹<%= order.total %></p>
    </div>

    <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/menu" class="w-full sm:w-auto text-center bg-orange-600 text-white px-6 py-3 rounded-lg hover:bg-orange-700 transition shadow-md">
        Back to Menu
      </a>
      <a href="/orders" class="w-full sm:w-auto text-center border border-orange-600 text-orange-600 px-6 py-3 rounded-lg hover:bg-orange-50 transition shadow-md">
        View Orders
      </a>
    </div>
  </div>

</body>
</html>
