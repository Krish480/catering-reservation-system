<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>MealMatrix - Menu</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="icon" href="/images/logo.png">
  <link rel="stylesheet" href="./css/style.css">
</head>

<body class="bg-gray-50 font-sans">

  <!-- Header -->
  <%- include("../partials/header") %>
    <br class="hidden"><br class="hidden">
    <br><br>

    <!-- Menu Section -->
    <section class="container mx-auto py-12 px-4">
      <div class="max-w-4xl mx-auto text-center mb-8">
        <h2 class="text-3xl font-bold text-gray-800">Our Menu</h2>
        <p class="text-gray-500 mt-2">Choose from our delicious varieties</p>
      </div>

      <!-- Search bar -->
      <div class="max-w-md mx-auto mb-8">
        <form id="search-form" class="flex">
          <input type="text" name="q" id="search-input" placeholder="Search for meals..."
            class="w-full px-4 py-2 border rounded-l-lg focus:outline-none">
          <button type="submit"
            class="bg-orange-600 text-white px-4 py-2 rounded-r-lg hover:bg-orange-700 transition">Search</button>
        </form>
      </div>

      <div id="menu-container" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        <!-- Items dynamically injected -->
      </div>
    </section>

    <!-- Footer -->
    <%- include("../partials/footer") %>
      <script>
        const USER_LOGGED_IN = <%= user ? true : false %>;
      </script>
      <script>
        let menuItemsCache = [];

        // Fetch menu items
        async function loadMenu() {
          const menuContainer = document.getElementById("menu-container");
          menuContainer.innerHTML = `<div class="col-span-full text-center py-8 text-gray-500">Loading menu...</div>`;

          try {
            const res = await fetch("/data/menu.json");
            if (!res.ok) throw new Error('Failed to fetch menu.json');
            const items = await res.json();
            menuItemsCache = items || [];
            menuContainer.innerHTML = "";

            const params = new URLSearchParams(window.location.search);
            const category = (params.get("category") || "").toLowerCase().trim();
            const searchQuery = (params.get("q") || "").toLowerCase().trim();

            let filteredItems = menuItemsCache;

            if (category) filteredItems = filteredItems.filter(i => String(i.category || "").toLowerCase() === category);
            if (searchQuery) filteredItems = filteredItems.filter(item =>
              item.name.toLowerCase().includes(searchQuery) ||
              (item.description && item.description.toLowerCase().includes(searchQuery))
            );

            if (!filteredItems || filteredItems.length === 0) {
              menuContainer.innerHTML = `<div class="col-span-full text-center py-12 text-gray-500">No items found.</div>`;
              return;
            }

            filteredItems.forEach(item => {
              const card = document.createElement('article');
              card.setAttribute('role', 'link');
              card.tabIndex = 0;
              card.setAttribute('data-id', item.id);
              card.className = 'bg-white p-4 shadow-sm rounded-xl hover:shadow-lg transition cursor-pointer flex flex-col';

              card.addEventListener('keydown', (ev) => {
                if (ev.key === 'Enter') window.location.href = `/product/${encodeURIComponent(item.id)}`;
              });
              card.addEventListener('click', () => window.location.href = `/product/${item.id}`);

              const imgWrap = document.createElement('div');
              imgWrap.className = 'relative rounded-md overflow-hidden flex justify-center items-center'; // 👈 center alignment yaha hoga

              const img = document.createElement('img');
              img.src = item.imageUrl || '/images/default-product.png';
              img.alt = item.name || 'Product';
              img.className = ' h-35 sm:h-36 drop-shadow-lg'; // 👈 fixed size for consistency
              imgWrap.appendChild(img);


              if (item.offer) {
                const badge = document.createElement('span');
                badge.textContent = item.offer;
                badge.className = 'absolute top-3 left-3 bg-red-500 text-white text-xs font-semibold px-2 py-1 rounded';
                imgWrap.appendChild(badge);
              }

              const content = document.createElement('div');
              content.className = 'mt-3 flex-1 flex flex-col';

              const title = document.createElement('h3');
              title.className = 'text-gray-800 text-lg font-semibold text-center';
              title.textContent = item.name || 'Unnamed';

              const desc = document.createElement('p');
              desc.className = 'text-sm text-gray-500 mt-2 text-center';

              // sirf 80 characters tak cut karo
              const shortDesc = item.description && item.description.length > 80
                ? item.description.substring(0, 80) + "..."
                : item.description || "";

              desc.textContent = shortDesc;


              const discountedPrice = item.offer ? Math.round(item.price * (1 - parseInt(item.offer) / 100)) : item.price;

              const priceRow = document.createElement('div');
              priceRow.className = 'mt-3 flex items-center justify-center gap-2';
              if (item.offer) {
                const originalPrice = document.createElement('div');
                originalPrice.className = 'text-gray-500 text-lg line-through';
                originalPrice.textContent = '₹' + item.price;
                priceRow.appendChild(originalPrice);
              }
              const price = document.createElement('div');
              price.className = 'text-orange-600 font-bold text-lg';
              price.textContent = '₹' + discountedPrice;
              priceRow.appendChild(price);

              const actions = document.createElement('div');
              actions.className = 'mt-4 flex items-center justify-center gap-3';

              const addBtn = document.createElement('button');
              addBtn.className = 'bg-orange-600 text-white px-4 py-2 rounded-full text-sm hover:bg-orange-700 transition';
              addBtn.textContent = 'Add to Cart';
              addBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                addToCartBackend(item.id);
              });

              const viewBtn = document.createElement('a');
              viewBtn.href = `/product/${item.id}`;
              viewBtn.className = 'border border-gray-200 px-4 py-2 rounded-full text-sm text-gray-700 hover:bg-gray-50 transition';
              viewBtn.textContent = 'View details';

              actions.appendChild(addBtn);
              actions.appendChild(viewBtn);

              content.appendChild(title);
              content.appendChild(desc);
              content.appendChild(priceRow);
              content.appendChild(actions);

              card.appendChild(imgWrap);
              card.appendChild(content);

              menuContainer.appendChild(card);
            });

          } catch (err) {
            console.error(err);
            menuContainer.innerHTML = "<div class='col-span-full text-center text-red-500 py-8'>Failed to load menu data.</div>";
          }
        }

        // Backend Add to Cart
        async function addToCartBackend(id) {
          if (!USER_LOGGED_IN) {
            window.location.href = '/login';
            return;
          }
          const item = menuItemsCache.find(x => String(x.id) === String(id));
          if (!item) { alert('Item not found'); return; }

          const discountedPrice = item.offer ? Math.round(item.price * (1 - parseInt(item.offer) / 100)) : item.price;

          try {
            const res = await fetch('/cart/add', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ item: { id: item.id, name: item.name, price: discountedPrice, imageUrl: item.imageUrl, quantity: 1 } })
            });
            const data = await res.json();
            if (data.success) {
              showToast(`${item.name} added to cart 🛒`);
              if (typeof updateCartCount === 'function')
                updateCartCount();
              fetchCartCount();
            } else alert('Failed to add to cart');
          } catch (err) {
            console.error(err);
            alert('Error adding to cart');
          }
        }

        // Fetch cart count from backend
        async function fetchCartCount() {
          try {
            const res = await fetch('/cart/data');
            const data = await res.json();
            const el = document.getElementById('cart-count');
            if (el) el.textContent = data.cartCount || 0;
          } catch (err) { console.error(err); }
        }

        function showToast(msg) {
          const t = document.createElement('div');
          t.textContent = msg;
          t.className = 'fixed top-6 right-4 bg-black/80 text-white px-4 py-2 rounded-lg shadow-lg z-50';
          document.body.appendChild(t);
          setTimeout(() => t.remove(), 1500);
        }

        window.addEventListener('DOMContentLoaded', () => {
          loadMenu();
          fetchCartCount();

          const searchForm = document.getElementById('search-form');
          const searchInput = document.getElementById('search-input');
          searchForm.addEventListener('submit', (e) => {
            e.preventDefault();
            const query = searchInput.value.trim();
            const url = new URL(window.location.href);
            if (query) url.searchParams.set('q', query);
            else url.searchParams.delete('q');
            window.location.href = url.toString();
          });
        });
      </script>

</body>

</html>