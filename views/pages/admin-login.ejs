<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login - MealMatrix</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen flex flex-col items-center justify-center px-4">

  <!-- Container -->
  <div class="w-full max-w-md bg-white rounded-2xl shadow-lg p-8 sm:p-10">
    <!-- Title -->
    <h2 class="text-3xl font-bold text-center text-orange-600 mb-6">Admin Login</h2>

    <!-- Error message -->
    <% if (error) { %>
      <div class="bg-red-100 text-red-700 px-4 py-3 rounded mb-4 text-center font-medium">
        <%= error %>
      </div>
    <% } %>

    <!-- Form -->
    <form method="POST" action="/admin/login" class="space-y-5">
      <div>
        <label class="block text-gray-700 mb-1 font-medium" for="email">Email</label>
        <input
          id="email"
          name="email"
          type="email"
          required
          placeholder="Enter your email"
          class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-orange-500 transition"
        />
      </div>

      <div>
        <label class="block text-gray-700 mb-1 font-medium" for="password">Password</label>
        <input
          id="password"
          name="password"
          type="password"
          required
          placeholder="Enter your password"
          class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-orange-500 transition"
        />
      </div>

      <button
        type="submit"
        class="w-full bg-orange-600 hover:bg-orange-700 text-white py-3 rounded-xl font-semibold transition"
      >
        Login
      </button>
    </form>

    <p class="mt-4 text-center text-gray-500 text-sm">
      &copy; 2025 MealMatrix. All rights reserved.
    </p>
  </div>

</body>
</html>
